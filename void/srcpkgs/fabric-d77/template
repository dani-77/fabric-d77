do_install() {
	vmkdir usr/share/fabric-d77
	vcopy "*.py" usr/share/fabric-d77
	vcopy assets usr/share/fabric-d77
	vcopy style.css usr/share/fabric-d77

	vbin ${FILESDIR}/fabric-d77
	vbin bin/fabric-d77-signal

	vinstall pam/fabric-d77 644 etc/pam.d fabric-d77

	vlicense LICENSE
}

conf_files="/etc/pam.d/fabric-d77"
